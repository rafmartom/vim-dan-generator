query (str): the string query to be embedded. page_numbers (List[str]): Filter by set of pages. Leave
BLANK if we want to perform a vector search over all pages. Otherwise, filter by the set of specified
pages. """ metadata_dicts = [{"key": "page_label", "value": p} for p in page_numbers] query_engine =
vector_index.as_query_engine( similarity_top_k=2, filters=MetadataFilters.from_dicts( metadata_dicts,
condition=FilterCondition.OR ), ) response = query_engine.query(query) return response vector_query_tool
= FunctionTool.from_defaults( fn=vector_query, # name='vector_query' )

