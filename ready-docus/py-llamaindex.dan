description=( "Provides information about Lyft financials for year 2021. " "Use a detailed plain text
question as input to the tool." ), ), ), QueryEngineTool( query_engine=uber_engine,
metadata=ToolMetadata( name="uber_10k", description=( "Provides information about Uber financials for
year 2021. " "Use a detailed plain text question as input to the tool." ), ), ), ]

