a community summary based on a given query using LLM.""" prompt = ( f"Given the community summary:
{community_summary}, " f"how would you answer the following query? Query: {query}" ) messages = [
ChatMessage(role="system", content=prompt), ChatMessage( role="user", content="I need an answer based on
the above information.", ), ] response = self.llm.chat(messages) cleaned_response =
re.sub(r"^assistant:\s*", "", str(response)).strip() return cleaned_response def aggregate_answers(self,
