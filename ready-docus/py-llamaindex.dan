ctx_dict = handler.ctx.to_dict(serializer=JsonSerializer()) # get the response from the user response_str
= input(input_ev.prefix).strip().lower() # restore the workflow restored_ctx = Context.from_dict(
workflow, ctx_dict, serializer=JsonSerializer() ) handler = workflow.run(ctx=restored_ctx)
handler.ctx.send_event( HumanResponseEvent( response=response_str, user_name=input_ev.user_name, ) )
response = await handler print(str(response))

