modules={ "input": agent_input_component, "retry_prompt": retry_prompt, "llm": llm, "sql_query_engine":
sql_query_engine, "output_component": agent_output_component, }, verbose=True, ) qp.add_link( "input",
"retry_prompt", dest_key="input", input_fn=lambda x: x["input"] ) qp.add_link( "input", "retry_prompt",
dest_key="convo_history", input_fn=lambda x: x["convo_history"], ) qp.add_chain(["retry_prompt", "llm",
"sql_query_engine", "output_component"])

