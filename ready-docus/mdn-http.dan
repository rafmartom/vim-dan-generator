| |   / _ \| '_ \| __/ _ \ '_ \| __|____|  _| | '_ \ / __/ _ \ / _` | | '_ \ 
| |__| (_) | | | | ||  __/ | | | ||_____| |___| | | | (_| (_) | (_| | | | | |
 \____\___/|_| |_|\__\___|_| |_|\__|    |_____|_| |_|\___\___/ \__,_|_|_| |_|
                                                                             
       
