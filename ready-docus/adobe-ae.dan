-   <L=U#5> Attributes </L>
    -   <L=U#6> CharacterRange.characterEnd </L>
    -   <L=U#9> CharacterRange.characterStart </L>
    -   <L=U#c> CharacterRange.fillColor </L>
    -   <L=U#f> CharacterRange.isRangeValid </L>
    -   <L=U#i> CharacterRange.kerning </L>
    -   <L=U#l> CharacterRange.strokeColor </L>
    -   <L=U#o> CharacterRange.strokeOverFill </L>
