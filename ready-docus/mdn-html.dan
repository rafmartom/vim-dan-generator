| '__/ _ \ |_____| '_ ` _ \ / _ \ / _` | | | | |/ _ \ '_ \| '__/ _ \ |/ _ \ 
| | |  __/ |_____| | | | | | (_) | (_| | |_| | |  __/ |_) | | |  __/ | (_) |
