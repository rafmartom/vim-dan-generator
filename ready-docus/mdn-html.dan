|_| |_| |_| |_|  |_|_____|  \__,_|\__|\__|_|  |_|_.__/ \__,_|\__\___(_)
                                                                       
       _                _           _     _           
 _ __ | | __ _  ___ ___| |__   ___ | | __| | ___ _ __ 
| '_ \| |/ _` |/ __/ _ \ '_ \ / _ \| |/ _` |/ _ \ '__|
| |_) | | (_| | (_|  __/ | | | (_) | | (_| |  __/ |   
| .__/|_|\__,_|\___\___|_| |_|\___/|_|\__,_|\___|_|   
